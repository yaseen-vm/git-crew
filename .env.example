# ── LLM Provider ───────────────────────────────────────────────────────────────
# Choose one provider. Set the matching API key below.
# Supported: groq | openai | anthropic | ollama | azure | mistral | google | openrouter | together

LLM_PROVIDER=groq

# Override the provider's default model (optional)
# LLM_MODEL=llama-3.3-70b-versatile

# ── Groq (default — free tier available) ───────────────────────────────────────
# Get key: https://console.groq.com
GROQ_API_KEY=your_groq_key_here

# ── OpenAI ─────────────────────────────────────────────────────────────────────
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# ── Anthropic (Claude) ─────────────────────────────────────────────────────────
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# ── Ollama (local, no API key needed) ──────────────────────────────────────────
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434   # optional, this is the default

# ── Azure OpenAI ───────────────────────────────────────────────────────────────
# LLM_PROVIDER=azure
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_VERSION=2024-02-01     # optional

# ── Mistral AI ─────────────────────────────────────────────────────────────────
# LLM_PROVIDER=mistral
# MISTRAL_API_KEY=...

# ── Google (Gemini) ────────────────────────────────────────────────────────────
# LLM_PROVIDER=google
# GOOGLE_API_KEY=...

# ── OpenRouter (access 100+ models via one API) ────────────────────────────────
# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=...
# LLM_MODEL=anthropic/claude-3.5-sonnet   # any model on openrouter.ai

# ── Together AI ────────────────────────────────────────────────────────────────
# LLM_PROVIDER=together
# TOGETHER_API_KEY=...
